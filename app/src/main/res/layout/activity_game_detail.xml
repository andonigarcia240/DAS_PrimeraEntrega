<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E2E"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2A2A3E"
        app:titleTextColor="#E8E8F0"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del juego *"
                android:textColor="#9090A8"
                android:textSize="12sp"/>

            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej: The Last of Us"
                android:textColor="#E8E8F0"
                android:textColorHint="#505068"
                android:backgroundTint="#7C9FD4"
                android:inputType="text"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Plataforma"
                android:textColor="#9090A8"
                android:textSize="12sp"/>

            <EditText
                android:id="@+id/etPlataforma"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej: PS5, PC, Nintendo Switch"
                android:textColor="#E8E8F0"
                android:textColorHint="#505068"
                android:backgroundTint="#7C9FD4"
                android:inputType="text"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Estado"
                android:textColor="#9090A8"
                android:textSize="12sp"/>

            <Spinner
                android:id="@+id/spinnerEstado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#7C9FD4"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Horas jugadas"
                android:textColor="#9090A8"
                android:textSize="12sp"/>

            <EditText
                android:id="@+id/etHoras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="0"
                android:textColor="#E8E8F0"
                android:textColorHint="#505068"
                android:backgroundTint="#7C9FD4"
                android:inputType="numberDecimal"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Puntuación (0-10)"
                android:textColor="#9090A8"
                android:textSize="12sp"/>

            <EditText
                android:id="@+id/etPuntuacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="0"
                android:textColor="#E8E8F0"
                android:textColorHint="#505068"
                android:backgroundTint="#7C9FD4"
                android:inputType="number"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Notas personales"
                android:textColor="#9090A8"
                android:textSize="12sp"/>

            <EditText
                android:id="@+id/etNotas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tus impresiones, trucos, donde lo dejaste..."
                android:textColor="#E8E8F0"
                android:textColorHint="#505068"
                android:backgroundTint="#7C9FD4"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"/>

            <Button
                android:id="@+id/btnBuscarWeb"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Buscar info del juego en web"
                android:backgroundTint="#3A3A55"
                android:textColor="#B0C4E8"/>

            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Guardar"
                android:backgroundTint="#7C9FD4"
                android:textColor="#1E1E2E"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>